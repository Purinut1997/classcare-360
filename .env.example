# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public application config
VITE_APP_NAME=ClassCare 360
VITE_APP_TIMEZONE=Asia/Bangkok

# Server-only secrets below must be configured in Supabase Edge Functions or Cloudflare,
# never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=server-only-do-not-prefix-with-vite
TELEGRAM_BOT_TOKEN=server-only
LINE_CHANNEL_ACCESS_TOKEN=server-only
LINE_CHANNEL_SECRET=server-only
GOOGLE_DRIVE_CLIENT_ID=server-only
GOOGLE_DRIVE_CLIENT_SECRET=server-only
GOOGLE_MAPS_API_KEY=server-or-restricted-browser-key
ENCRYPTION_KEY=server-only
