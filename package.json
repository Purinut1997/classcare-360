{
  "name": "classcare-360",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:sites": "npm run build && node scripts/create-sites-worker.mjs",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name classcare-360",
    "check:deploy": "node scripts/check-production-readiness.mjs",
    "check:supabase": "node scripts/check-supabase-connection.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.2",
    "read-excel-file": "^9.2.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.18.1"
  }
}
